+  /**
+   * Helper function to prepare min and max values based on parsed dates.
+   *
+   * @return array
+   *   An array containing the min and max timestamp values.
+   */
+  protected function getMinAndMax() {
+    $timezone = $this->getTimezone();
+    $granularity = $this->options['granularity'];
+
+    if (count($this->parsedDates) === 1) {
+      // Single date - create min/max based on granularity
+      $date = new DateTimePlus($this->parsedDates[0], new \DateTimeZone($timezone));
+      $a = $b = $date;
+    } else {
+      // Date range provided
+      $a = new DateTimePlus($this->parsedDates[0], new \DateTimeZone($timezone));
+      $b = new DateTimePlus($this->parsedDates[1], new \DateTimeZone($timezone));
+    }
+
+    $min = [
+      'year' => $a->format('Y'),
+      'month' => $a->format('n'),
+      'day' => $a->format('j'),
+      'hour' => $a->format('G'),
+      'minute' => $a->format('i'),
+      'second' => $a->format('s'),
+    ];
+    $max = [
+      'year' => $b->format('Y'),
+      'month' => $b->format('n'),
+      'day' => $b->format('j'),
+      'hour' => $b->format('G'),
+      'minute' => $b->format('i'),
+      'second' => $b->format('s'),
+    ];
+
+    // Apply granularity adjustments
+    switch ($granularity) {
+      case 'year':
+        $min['month'] = '01';
+        $max['month'] = '12';
+        $max['day'] = '31';
+        // fall through
+      case 'month':
+        $min['day'] = '01';
+        if ($granularity !== 'year') {
+          $max['day'] = $b->format('t');
+        }
+        // fall through
+      case 'week':
+        // Calculate week range from Saturday to Sunday
+        $week_range = $this->calculateWeekRange($a);
+        $min = [
+          'year' => $week_range['start']->format('Y'),
+          'month' => $week_range['start']->format('n'),
+          'day' => $week_range['start']->format('j'),
+          'hour' => '00',
+          'minute' => '00',
+          'second' => '00',
+        ];
+        $max = [
+          'year' => $week_range['end']->format('Y'),
+          'month' => $week_range['end']->format('n'),
+          'day' => $week_range['end']->format('j'),
+          'hour' => '23',
+          'minute' => '59',
+          'second' => '59',
+        ];
+        break;
+      case 'day':
+        $min['hour'] = '00';
+        $max['hour'] = '23';
+        // fall through
+      case 'hour':
+        $min['minute'] = '00';
+        $max['minute'] = '59';
+        // fall through
+      case 'minute':
+        $min['second'] = '00';
+        $max['second'] = '59';
+        break;
+    }
+
+    $min_value = $a::createFromArray($min, $timezone)->format('U');
+    $max_value = $b::createFromArray($max, $timezone)->format('U');
+    return [$min_value, $max_value];
+  }
+
+  /**
+   * Calculate week range from Saturday to Sunday for a given date.
+   *
+   * @param \Drupal\Component\Datetime\DateTimePlus $date
+   *   The reference date.
+   *
+   * @return array
+   *   Array with 'start' and 'end' DateTimePlus objects representing the week range.
+   */
+  protected function calculateWeekRange(DateTimePlus $date) {
+    $timezone = $date->getTimezone();
+    
+    // Get the day of week (0 = Sunday, 6 = Saturday)
+    $day_of_week = (int) $date->format('w');
+    
+    // Calculate days to previous Saturday
+    // If today is Saturday (6), days_to_saturday = 0
+    // If today is Sunday (0), days_to_saturday = 1  
+    // If today is Monday (1), days_to_saturday = 2, etc.
+    $days_to_saturday = ($day_of_week + 1) % 7;
+    
+    // Calculate days to next Sunday
+    // If today is Saturday (6), days_to_sunday = 1
+    // If today is Sunday (0), days_to_sunday = 0
+    // If today is Monday (1), days_to_sunday = 6, etc.
+    $days_to_sunday = (7 - $day_of_week) % 7;
+    
+    // Create start date (previous Saturday)
+    $start = clone $date;
+    if ($days_to_saturday > 0) {
+      $start->sub(new \DateInterval('P' . $days_to_saturday . 'D'));
+    }
+    
+    // Create end date (next Sunday)
+    $end = clone $date;
+    if ($days_to_sunday > 0) {
+      $end->add(new \DateInterval('P' . $days_to_sunday . 'D'));
+    }
+    
+    return [
+      'start' => $start,
+      'end' => $end,
+    ];
+  }
