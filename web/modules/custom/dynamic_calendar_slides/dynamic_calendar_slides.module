<?php

/**
 * @file
 * Primary module hooks for dynamic calendar slides module.
 */

 /**
 * Implements hook_fullcalendar_view_alter().
 */
function dynamic_calendar_slides_fullcalendar_view_alter(array &$view, array &$fullcalendar_settings) {
  // Replace with your view ID and block machine name.
  if ($view['id'] === 'interactive_calendar_events') {
    $view['#attached']['library'][] = 'dynamic_calnder_slides/dynamic_calnder_slides.fullcalendar_interaction';
  }
}

